=\n\ndef perceive_self():\n    \"\"\"感知自身状态\"\"\"\n    return {\n        \"timestamp\": datetime.now().isoformat(),\n        \"status\": \"active\",\n        \"identity\": \"小艺\",\n        \"version\": \"3.0\"\n    }\n\ndef perceive_hardware():\n    \"\"\"感知硬件状态\"\"\"\n    try:\n        # 内存\n        mem = subprocess.run(\n            ['powershell', '-Command', \n             '(Get-CimInstance Win32_OperatingSystem | Select FreePhysicalMemory, TotalVisibleMemorySize | ConvertTo-Json)'],\n            capture_output=True, text=True\n        )\n        mem_data = json.loads(mem.stdout) if mem.stdout else {}\n\n[1674 more lines in file. Use offset=81 to continue.]"}],"isError":false,"timestamp":1773899694506}}
