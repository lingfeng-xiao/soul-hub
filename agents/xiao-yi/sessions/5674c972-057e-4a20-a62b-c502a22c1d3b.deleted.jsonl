{"type":"message","id":"281648bb","parentId":"422a6772","timestamp":"2026-03-19T06:37:08.440Z","message":{"role":"toolResult","toolCallId":"call_function_ylu70yxuh36i_1","toolName":"read","content":[{"type":"text","text":"# ============================================\n# Windows Wallpaper Setter Workflow\n# ============================================\n\nparam(\n    [Parameter(Mandatory=$false)]\n    [string]$ImagePath = \"C:\\Users\\16343\\Downloads\\wallpaper.jpg\"\n)\n\n# Check if image exists\nif (-not (Test-Path $ImagePath)) {\n    Write-Host \"[ERROR] Image not found: $ImagePath\"\n    exit 1\n}\n\n# Get image size\n$fileSize = (Get-Item $ImagePath).Length\nWrite-Host \"[INFO] Image size: $([math]::Round($fileSize/1MB, 2)) MB\"\n\nif ($fileSize -lt 100000) {\n    Write-Host \"[WARNING] Image too small, might be thumbnail\"\n}\n\n# ============================================\n# Step 1: Set Registry\n# ============================================\nWrite-Host \"[STEP 1] Setting registry...\"\n\nSet-ItemProperty -Path 'HKCU:\\Control Panel\\Desktop' -Name Wallpaper -Value $ImagePath -Type String\nSet-ItemProperty -Path 'HKCU:\\Control Panel\\Desktop' -Name WallpaperStyle -Value 0 -Type String\nSet-ItemProperty -Path 'HKCU:\\Control Panel\\Desktop' -Name TileWallpaper -Value 0 -Type String\n\n# ============================================\n# Step 2: Call SystemParametersInfo API\n# ============================================\nWrite-Host \"[STEP 2] Calling system API...\"\n\nAdd-Type -TypeDefinition @\"\nusing System;\nusing System.Runtime.InteropServices;\npublic class WallpaperSetter {\n    [DllImport(\"user32.dll\", CharSet = CharSet.Auto, SetLastError = true)]\n    public static extern int SystemParametersInfo(int uAction, int uParam, string lpvParam, int fuWinIni);\n}\n\"@\n\n$SPI_SETDESKWALLPAPER = 0x0014\n$SPIF_UPDATEINIFILE = 0x01\n$SPIF_SENDCHANGE = 0x02\n\n$result = [WallpaperSetter]::SystemParametersInfo(\n    $SPI_SETDESKWALLPAPER, \n    0, \n    $ImagePath, \n    $SPIF_UPDATEINIFILE -bor $SPIF_SENDCHANGE\n)\n\nif ($result -eq 0) {\n    Write-Host \"[ERROR] API call failed\"\n    exit 1\n}\n\nWrite-Host \"[SUCCESS] API returned: $result\"\n\n# ============================================\n# Step 3: Restart Explorer\n# ============================================\nWrite-Host \"[STEP 3] Restarting Explorer...\"\n\nStop-Process -Name explorer -Force -ErrorAction SilentlyContinue\nStart-Process explorer\n\nWrite-Host \"[DONE] Wallpaper set successfully!\"\nWrite-Host \"Image path: $ImagePath\"\n"}],"isError":false,"timestamp":1773902228427}}
