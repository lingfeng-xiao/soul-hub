x0014\n$SPIF_UPDATEINIFILE = 0x01\n$SPIF_SENDCHANGE = 0x02\n\n$result = [WallpaperSetter]::SystemParametersInfo(\n    $SPI_SETDESKWALLPAPER, \n    0, \n    $ImagePath, \n    $SPIF_UPDATEINIFILE -bor $SPIF_SENDCHANGE\n)\n\nif ($result -eq 0) {\n    Write-Host \"[ERROR] API call failed\"\n    exit 1\n}\n\nWrite-Host \"[SUCCESS] API returned: $result\"\n\n# ============================================\n# Step 3: Restart Explorer\n# ============================================\nWrite-Host \"[STEP 3] Restarting Explorer...\"\n\nStop-Process -Name explorer -Force -ErrorAction SilentlyContinue\nStart-Process explorer\n\nWrite-Host \"[DONE] Wallpaper set successfully!\"\nWrite-Host \"Image path: $ImagePath\"\n","path":"C:\\Users\\16343\\Downloads\\set-wallpaper.ps1"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":107935,"output":629,"cacheRead":36936,"cacheWrite":0,"totalTokens":145500,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773735016944}}
