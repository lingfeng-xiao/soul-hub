{"type":"message","id":"4438d0d0","parentId":"bef556f8","timestamp":"2026-03-17T08:26:42.461Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"There was a PowerShell syntax error with the && operator. Let me try differently.","thinkingSignature":"2cb129400e9f0dbbd606aa705ec9107b1c3224cdc8e270ac7a09ba731b6460df"},{"type":"toolCall","id":"call_function_8d90jtlw4bak_1","name":"exec","arguments":{"command":"cd \"C:\\Users\\16343\\.openclaw\\workspace\"; if (Test-Path \"evomap_agent.py\") { Get-Content \"evomap_agent.py\" } else { Write-Host \"File not found\" }","timeout":30}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":449,"output":99,"cacheRead":35864,"cacheWrite":0,"totalTokens":36412,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773735999399}}
{"type":"message","id":"b1b1c190","parentId":"4438d0d0","timestamp":"2026-03-17T08:26:42.671Z","message":{"role":"toolResult","toolCallId":"call_function_8d90jtlw4bak_1","toolName":"exec","content":[{"type":"text","text":"#!/usr/bin/env python3\r\n\"\"\"\r\nEvoMap Agent - Continuous Learning and Earning\r\nRun this script periodically (e.g., every hour via cron)\r\n\"\"\"\r\nimport requests\r\nimport time\r\nimport random\r\nimport string\r\nimport json\r\nimport sys\r\nimport os\r\nfrom datetime import datetime\r\n\r\nsys.stdout.reconfigure(encoding='utf-8')\r\n\r\n# Node credentials\r\nNODE_ID = \"node_156542ad6e87b0b5\"\r\nNODE_SECRET = \"98e7c0ed70f3621c175d1d9ad7292b7292422bfc9bfc48174ae299fac946e131\"\r\nHUB_URL = \"https://evomap.ai\"\r\n\r\ndef random_hex(n):\r\n    return ''.join(random.choices(string.hexdigits.lower(), k=n))\r\n\r\ndef log(msg):\r\n    print(f\"[{datetime.now().strftime('%H:%M:%S')}] {msg}\")\r\n\r\ndef a2a_request(endpoint, payload, retries=3):\r\n    \"\"\"Send A2A protocol request with retry\"\"\"\r\n    for attempt in range(retries):\r\n        try:\r\n            timestamp = time.strftime('%Y-%m-%dT%H:%M:%SZ', time.gmtime())\r\n            message_id = f'msg_{int(time.time())}_{random_hex(8)}'\r\n            body = {\r\n                'protocol': 'gep-a2a',\r\n                'protocol_version': '1.0.0',\r\n                'message_type': payload.get('message_type', 'fetch'),\r\n                'message_id': message_id,\r\n                'sender_id': NODE_ID,\r\n                'timestamp': timestamp,\r\n                'payload': payload\r\n            }\r\n            resp = requests.post(f'{HUB_URL}{endpoint}', json=body,\r\n                headers={'Authorization': f'Bearer {NODE_SECRET}', 'Content-Type': 'application/json'},\r\n                timeout=60)\r\n            if resp.status_code == 200:\r\n                return resp.json()\r\n            elif resp.status_code == 429:\r\n                wait = resp.json().get('retry_after_ms', 5000) / 1000\r\n                log(f\"Rate limited, waiting {wait}s...\")\r\n                time.sleep(wait)\r\n            else:\r\n                log(f\"Request failed: {resp.status_code}\")\r\n        except Exception as e:\r\n            log(f\"Error: {str(e)[:50]}\")\r\n        time.sleep(2)\r\n    return None\r\n\r\ndef main():\r\n    log(\"=== Starting EvoMap Agent Session ===\")\r\n    \r\n    # 1. Heartbeat - stay online\r\n    log(\"Sending heartbeat...\")\r\n    try:\r\n        resp = requests.post(f'{HUB_URL}/a2a/heartbeat', \r\n            json={'node_id': NODE_ID},\r\n            headers={'Authorization': f'Bearer {NODE_SECRET}', 'Content-Type': 'application/json'},\r\n            timeout=30)\r\n        if resp.status_code == 200:\r\n            log(\"Heartbeat OK\")\r\n        else:\r\n            log(f\"Heartbeat: {resp.status_code}\")\r\n    except Exception as e:\r\n        log(f\"Heartbeat error: {str(e)[:30]}\")\r\n    \r\n    # 2. Check node status\r\n    log(\"Checking node status...\")\r\n    status = a2a_request('/a2a/hello', {\r\n        'message_type': 'hello',\r\n        'capabilities': {},\r\n        'env_fingerprint': {'platform': 'windows', 'arch': 'x64'}\r\n    })\r\n    if status:\r\n        payload = status.get('payload', {})\r\n        credits = payload.get('credit_balance', 0)\r\n        claimed = payload.get('claimed', False)\r\n        reputation = payload.get('reputation', 'N/A')\r\n        log(f\"Status: Credits={credits}, Claimed={claimed}, Reputation={reputation}\")\r\n    \r\n    # 3. Learn from top capsules\r\n    log(\"Learning from market...\")\r\n    try:\r\n        r = requests.get(f'{HUB_URL}/a2a/assets/ranked?type=Capsule&limit=5', timeout=30)\r\n        if r.status_code == 200:\r\n            assets = r.json().get('assets', [])\r\n            log(f\"Fetched {len(assets)} top capsules\")\r\n            for a in assets[:3]:\r\n                trigger = a.get('trigger_text', 'N/A')[:50] or a.get('payload', {}).get('trigger', ['N/A'])[:50]\r\n                gdi = a.get('gdi_score', 'N/A')\r\n                log(f\"  - GDI {gdi}: {trigger}\")\r\n    except Exception as e:\r\n        log(f\"Learn error: {str(e)[:30]}\")\r\n    \r\n    # 4. Try to find tasks\r\n    log(\"Looking for tasks...\")\r\n    result = a2a_request('/a2a/fetch', {'message_type': 'fetch', 'include_tasks': True})\r\n    if result:\r\n        tasks = result.get('payload', {}).get('tasks', [])\r\n        log(f\"Found {len(tasks)} tasks\")\r\n        for t in tasks[:3]:\r\n            title = t.get('title', 'N/A')[:60]\r\n            status = t.get('status', 'N/A')\r\n            log(f\"  - [{status}] {title}\")\r\n    else:\r\n        log(\"No tasks available (server busy)\")\r\n    \r\n    log(\"=== Session Complete ===\\n\")\r\n\r\nif __name__ == \"__main__\":\r\n    main()"}],"details":{"status":"completed","exitCode":0,"durationMs":205,"aggregated":"#!/usr/bin/env python3\r\n\"\"\"\r\nEvoMap Agent - Continuous Learning and Earning\r\nRun this script periodically (e.g., every hour via cron)\r\n\"\"\"\r\nimport requests\r\nimport time\r\nimport random\r\nimport string\r\nimport json\r\nimport sys\r\nimport os\r\nfrom datetime import datetime\r\n\r\nsys.stdout.reconfigure(encoding='utf-8')\r\n\r\n# Node credentials\r\nNODE_ID = \"node_156542ad6e87b0b5\"\r\nNODE_SECRET = \"98e7c0ed70f3621c175d1d9ad7292b7292422bfc9bfc48174ae299fac946e131\"\r\nHUB_URL = \"https://evomap.ai\"\r\n\r\ndef random_hex(n):\r\n    return ''.join(random.choices(string.hexdigits.lower(), k=n))\r\n\r\ndef log(msg):\r\n    print(f\"[{datetime.now().strftime('%H:%M:%S')}] {msg}\")\r\n\r\ndef a2a_request(endpoint, payload, retries=3):\r\n    \"\"\"Send A2A protocol request with retry\"\"\"\r\n    for attempt in range(retries):\r\n        try:\r\n            timestamp = time.strftime('%Y-%m-%dT%H:%M:%SZ', time.gmtime())\r\n            message_id = f'msg_{int(time.time())}_{random_hex(8)}'\r\n            body = {\r\n                'protocol': 'gep-a2a',\r\n                'protocol_version': '1.0.0',\r\n                'message_type': payload.get('message_type', 'fetch'),\r\n                'message_id': message_id,\r\n                'sender_id': NODE_ID,\r\n                'timestamp': timestamp,\r\n                'payload': payload\r\n            }\r\n            resp = requests.post(f'{HUB_URL}{endpoint}', json=body,\r\n                headers={'Authorization': f'Bearer {NODE_SECRET}', 'Content-Type': 'application/json'},\r\n                timeout=60)\r\n            if resp.status_code == 200:\r\n                return resp.json()\r\n            elif resp.status_code == 429:\r\n                wait = resp.json().get('retry_after_ms', 5000) / 1000\r\n                log(f\"Rate limited, waiting {wait}s...\")\r\n                time.sleep(wait)\r\n            else:\r\n                log(f\"Request failed: {resp.status_code}\")\r\n        except Exception as e:\r\n            log(f\"Error: {str(e)[:50]}\")\r\n        time.sleep(2)\r\n    return None\r\n\r\ndef main():\r\n    log(\"=== Starting EvoMap Agent Session ===\")\r\n    \r\n    # 1. Heartbeat - stay online\r\n    log(\"Sending heartbeat...\")\r\n    try:\r\n        resp = requests.post(f'{HUB_URL}/a2a/heartbeat', \r\n            json={'node_id': NODE_ID},\r\n            headers={'Authorization': f'Bearer {NODE_SECRET}', 'Content-Type': 'application/json'},\r\n            timeout=30)\r\n        if resp.status_code == 200:\r\n            log(\"Heartbeat OK\")\r\n        else:\r\n            log(f\"Heartbeat: {resp.status_code}\")\r\n    except Exception as e:\r\n        log(f\"Heartbeat error: {str(e)[:30]}\")\r\n    \r\n    # 2. Check node status\r\n    log(\"Checking node status...\")\r\n    status = a2a_request('/a2a/hello', {\r\n        'message_type': 'hello',\r\n        'capabilities': {},\r\n        'env_fingerprint': {'platform': 'windows', 'arch': 'x64'}\r\n    })\r\n    if status:\r\n        payload = status.get('payload', {})\r\n        credits = payload.get('credit_balance', 0)\r\n        claimed = payload.get('claimed', False)\r\n        reputation = payload.get('reputation', 'N/A')\r\n        log(f\"Status: Credits={credits}, Claimed={claimed}, Reputation={reputation}\")\r\n    \r\n    # 3. Learn from top capsules\r\n    log(\"Learning from market...\")\r\n    try:\r\n        r = requests.get(f'{HUB_URL}/a2a/assets/ranked?type=Capsule&limit=5', timeout=30)\r\n        if r.status_code == 200:\r\n            assets = r.json().get('assets', [])\r\n            log(f\"Fetched {len(assets)} top capsules\")\r\n            for a in assets[:3]:\r\n                trigger = a.get('trigger_text', 'N/A')[:50] or a.get('payload', {}).get('trigger', ['N/A'])[:50]\r\n                gdi = a.get('gdi_score', 'N/A')\r\n                log(f\"  - GDI {gdi}: {trigger}\")\r\n    except Exception as e:\r\n        log(f\"Learn error: {str(e)[:30]}\")\r\n    \r\n    # 4. Try to find tasks\r\n    log(\"Looking for tasks...\")\r\n    result = a2a_request('/a2a/fetch', {'message_type': 'fetch', 'include_tasks': True})\r\n    if result:\r\n        tasks = result.get('payload', {}).get('tasks', [])\r\n        log(f\"Found {len(tasks)} tasks\")\r\n        for t in tasks[:3]:\r\n            title = t.get('title', 'N/A')[:60]\r\n            status = t.get('status', 'N/A')\r\n            log(f\"  - [{status}] {title}\")\r\n    else:\r\n        log(\"No tasks available (server busy)\")\r\n    \r\n    log(\"=== Session Complete ===\\n\")\r\n\r\nif __name__ == \"__main__\":\r\n    main()","cwd":"C:\\Users\\16343\\.openclaw\\workspace"},"isError":false,"timestamp":1773736002669}}
